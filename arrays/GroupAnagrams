
/**
 * Group Anagrams - Sorting Solution
 * 
 * Time: O(m * n log n) 
 * Space: O(m) since hashmap store m as strings
 */
class Solution {
    public List<List<String>> groupAnagrams(String[] strs) {
        Map<String, List<String>> map = new HashMap<>();
        
        for (String s : strs) {
            char[] chars = s.toCharArray();    // Convert to char array
            Arrays.sort(chars);                 // Sort characters
            String key = new String(chars);     // Sorted string = key
            
            map.putIfAbsent(key, new ArrayList<>());
            map.get(key).add(s);
        }
        
        return new ArrayList<>(map.values());
    }
}
